# Copiar a .env y ajustar valores antes de levantar el stack con docker compose.
# .env no se versiona (ver .gitignore).

# PostgreSQL (auth_db, items_db)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# MongoDB (logs_db)
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=root

# RabbitMQ (mensajería logs -> analysis)
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# JWT: auth-service la usa para FIRMAR tokens; alert-service la usa para
# VERIFICAR el rol admin en PATCH /alerts/:id (Semana 10) — debe ser la misma
# clave en ambos servicios.
JWT_SECRET_KEY=changeme-super-secret-key-for-jwt-in-production

# CORS: orígenes permitidos separados por coma, sin espacios finales
# El dashboard ahora sirve por HTTPS (puerto 443, ver certs/generate-dev-cert.sh)
CORS_ORIGINS=https://localhost
